# LOKA custom kernel config — appended to defconfig.
# Minimal virtio-only kernel for lokavm microVMs.
# Version: 6.12.8 (pinned)

# Virtio devices (all built-in, no modules)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HVC_DRIVER=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y
CONFIG_VIRTIO_FS=y

# Filesystem
CONFIG_OVERLAY_FS=y
CONFIG_FUSE_FS=y
CONFIG_BLK_DEV_LOOP=y

# NFS (for store volumes)
CONFIG_NFS_FS=y
CONFIG_NFS_V4=y
CONFIG_SUNRPC=y

# Networking core
CONFIG_NET=y
CONFIG_INET=y
CONFIG_UNIX=y
CONFIG_PACKET=y
CONFIG_NET_NS=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y
CONFIG_ETHTOOL_NETLINK=y
CONFIG_DNS_RESOLVER=y
CONFIG_UNIX98_PTYS=y

# Namespaces (needed for containers, iproute2)
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_USER_NS=y
CONFIG_UTS_NS=y
CONFIG_TIME_NS=y

# Networking / firewall
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_NAT=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_FILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_TUN=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_NET_SCHED=y

# Cgroups
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y

# CPU hotplug
CONFIG_HOTPLUG_CPU=y
