# LOKA Worker Agent
FROM golang:1.24-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath \
    -ldflags "-s -w" \
    -o /loka-worker ./cmd/loka-worker

# Runtime — needs to be privileged for Firecracker/KVM
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata iptables

COPY --from=builder /loka-worker /usr/local/bin/loka-worker

EXPOSE 9090

ENTRYPOINT ["loka-worker"]
