# LOKA Control Plane
FROM golang:1.24-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath \
    -ldflags "-s -w" \
    -o /lokad ./cmd/lokad

# Runtime
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata
RUN adduser -D -u 1000 loka

COPY --from=builder /lokad /usr/local/bin/lokad

USER loka
EXPOSE 8080 9090

ENTRYPOINT ["lokad"]
